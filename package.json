{
  "name": "technaveia-api",
  "version": "1.0.0",
  "description": "API backend da plataforma TechNaVeia",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "npx prisma generate && tsc",
